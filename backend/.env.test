# =============================================================================
# Finance Dashboard Backend - TEST Environment Variables
# =============================================================================
# This file is loaded automatically by Jest (via jest.config.js).
# The test database MUST be a separate database from development/production.
# The DATABASE_URL MUST contain '_test' as a safety check.
# =============================================================================

# REQUIRED - Test database (MUST contain '_test' in the name)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_dashboard_test"

# REQUIRED - JWT secret for test token generation
JWT_SECRET="test-jwt-secret-key-for-testing-only"

# Test CORS (not actually used in tests, but prevents startup errors)
CORS_ORIGIN="http://localhost:5500"
