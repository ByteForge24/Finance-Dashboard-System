{
  "name": "finance-dashboard-backend",
  "version": "1.0.0",
  "description": "Finance Dashboard System - Backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "setup": "npm install && npm run db:migrate && npm run db:seed",
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:cov": "jest --runInBand --coverage",
    "smoke": "tsx scripts/smoke-test.ts",
    "verify:seed": "tsx scripts/verify-production-seed.ts",
    "verify:seed:prod": "NODE_ENV=production tsx scripts/verify-production-seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "jest": "^29.5.0",
    "prisma": "^5.8.0",
    "rimraf": "^5.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "tsx": "^3.12.7",
    "typescript": "^5.1.3"
  }
}
