# Supabase PostgreSQL Connection (production)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Get this connection string from Supabase dashboard → Settings → Database
DATABASE_URL="postgresql://postgres:FinanceDashboard2026!Secure@db.wdwlijnkisqlnuwmoidh.supabase.co:5432/postgres"

# Production JWT Secret (MUST be strong random string)
# Generate with: openssl rand -base64 48
JWT_SECRET="[CHANGE-TO-STRONG-RANDOM-SECRET-MIN-32-CHARS]"

# Production Server Port
PORT=3000

# Production Frontend URL (Netlify)
CORS_ORIGIN="https://finance-dashboard.netlify.app"

# Optional: Production OpenAI API key
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-mini

# Node Environment
NODE_ENV=production
