# =============================================================================
# Finance Dashboard Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The server will REFUSE TO START if required variables are missing.
# =============================================================================

# REQUIRED - PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/finance_dashboard"

# REQUIRED - JWT signing secret (use a long random string, e.g. openssl rand -base64 48)
JWT_SECRET="CHANGE-ME-to-a-long-random-secret"

# OPTIONAL - Server port (defaults to 3000)
PORT=3000

# OPTIONAL - Allowed CORS origins (comma-separated)
# In development: If not set, all origins are allowed.
# In production: If not set, ALL cross-origin requests are BLOCKED.
# Example: CORS_ORIGIN=https://app.example.com,https://staging.example.com
CORS_ORIGIN=

# =============================================================================
# AI Configuration - Category Suggestions (OPTIONAL)
# =============================================================================
# If not provided, the system uses fallback keyword-based suggestions
# and the backend starts successfully without AI capabilities.

# Optional - OpenAI API key for category suggestions
# Sign up at https://platform.openai.com to get an API key
# OPENAI_API_KEY=sk-...

# Optional - OpenAI model (defaults to gpt-4-mini)
# Currently supported: gpt-4-mini, gpt-3.5-turbo
# OPENAI_MODEL=gpt-4-mini

# Optional - Timeout for OpenAI API calls in milliseconds (defaults to 3000)
# OPENAI_TIMEOUT_MS=3000
CORS_ORIGIN="http://localhost:5500"
