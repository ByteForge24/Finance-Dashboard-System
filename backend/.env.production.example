# Finance Dashboard - Production Environment (EXAMPLE)
# =====================================================
# DO NOT commit actual values - use Render environment variables instead
# Copy values from Supabase dashboard and enter in Render dashboard

# Supabase runtime connection (Transaction Pooler)
# Get from: Supabase → Settings → Database → Connection pooling → Transaction mode
# Use the pooled connection for the running API.
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require"

# Supabase schema connection for Prisma schema commands
# Get from: Supabase → Settings → Database → Connection pooling → Session mode
# Use the session pooler connection for `prisma db push` / `prisma migrate` on Render.
DIRECT_URL="postgresql://postgres.[PROJECT_ID]:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require"

# Strong JWT Secret (generate with: openssl rand -base64 48)
JWT_SECRET="[GENERATE-STRONG-RANDOM-SECRET-MIN-32-CHARS]"

# Production Server
PORT=3000

# Production Frontend URL (Netlify - update after frontend deployment)
CORS_ORIGIN="https://finance-dashboard-pro.netlify.app"

# Optional: Production OpenAI API key
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-mini

# Node Environment
NODE_ENV=production
