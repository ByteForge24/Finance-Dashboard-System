# Finance Dashboard - Production Environment (EXAMPLE)
# =====================================================
# DO NOT commit actual values - use Render environment variables instead
# Copy values from Supabase dashboard and enter in Render dashboard

# Supabase PostgreSQL Connection
# Get from: Supabase → Settings → Database → Connection Strings → PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Strong JWT Secret (generate with: openssl rand -base64 48)
JWT_SECRET="[GENERATE-STRONG-RANDOM-SECRET-MIN-32-CHARS]"

# Production Server
PORT=3000

# Production Frontend URL (Netlify - update after frontend deployment)
CORS_ORIGIN="https://finance-dashboard.netlify.app"

# Optional: Production OpenAI API key
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-mini

# Node Environment
NODE_ENV=production
