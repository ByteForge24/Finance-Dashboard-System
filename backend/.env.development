# Finance Dashboard - Development Environment
# =============================================

# LOCAL PostgreSQL for development (default)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_dashboard_dev"

# JWT Secret (local testing - NOT secure, for dev only)
JWT_SECRET="dev-only-secret-do-not-use-in-production-change-this"

# Development Server
PORT=3000

# Allow local frontend development
CORS_ORIGIN="http://localhost:5500,http://127.0.0.1:5000"

# AI Configuration (optional - leave empty to use fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-mini
